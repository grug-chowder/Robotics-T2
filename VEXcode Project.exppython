{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain = Brain()\n\n# Robot configuration code\nbrain_inertial = Inertial()\noptical_1 = Optical(Ports.PORT1)\nmotor_2 = Motor(Ports.PORT2, False)\nmotor_3 = Motor(Ports.PORT3, False)\n\n\n# Wait for sensor(s) to fully initialize\nwait(100, MSEC)\n\n# generating and setting random seed\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    xaxis = brain_inertial.acceleration(XAXIS) * 1000\n    yaxis = brain_inertial.acceleration(YAXIS) * 1000\n    zaxis = brain_inertial.acceleration(ZAXIS) * 1000\n    systemTime = brain.timer.system() * 100\n    urandom.seed(int(xaxis + yaxis + zaxis + systemTime)) \n\n# Initialize random seed \ninitializeRandomSeed()\n\n\n# Color to String Helper\ndef convert_color_to_string(col):\n    if col == Color.RED:\n        return \"red\"\n    if col == Color.GREEN:\n        return \"green\"\n    if col == Color.BLUE:\n        return \"blue\"\n    if col == Color.WHITE:\n        return \"white\"\n    if col == Color.YELLOW:\n        return \"yellow\"\n    if col == Color.ORANGE:\n        return \"orange\"\n    if col == Color.PURPLE:\n        return \"purple\"\n    if col == Color.CYAN:\n        return \"cyan\"\n    if col == Color.BLACK:\n        return \"black\"\n    if col == Color.TRANSPARENT:\n        return \"transparent\"\n    return \"\"\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n#   Project:      VEXcode Project\n#   Author:       VEX\n#   Description:  VEXcode EXP Python Project - Fast Colour Sorter\n# ------------------------------------------\n\nfrom vex import *\n\nbrain.screen.print(\"VEXcode\")\n\n\ndef bounds(hue_x, brightness_y, goal):\n    #          hue_min, hue_max, bright_min, bright_max\n    a_bounds = [190, 240, 20, 101]  # blue\n    b_bounds = [0, 10, 16, 65]      # red\n    c_bounds = [60, 85, 30, 101]    # green\n\n    if goal == \"A\":\n        b = a_bounds\n    elif goal == \"B\":\n        b = b_bounds\n    elif goal == \"C\":\n        b = c_bounds\n    else:\n        return False\n\n    if (hue_x >= b[0]\n            and hue_x <= b[1]\n            and brightness_y >= b[2]\n            and brightness_y <= b[3]):\n        return True\n    else:\n        return False\n\n\ndef marbleA():\n    brain.screen.print(\"blue\")\n    motor_2.spin_to_position(00,DEGREES,wait=True)\n    motor_3.spin_to_position(-90, DEGREES)\n\n\ndef marbleB():\n    brain.screen.print(\"red\")\n    motor_2.spin_to_position(120,DEGREES,wait=True)\n    motor_3.spin_to_position(-90, DEGREES)\n\n\ndef marbleC():\n    brain.screen.print(\"green\")\n    motor_2.spin_to_position(240,DEGREES,wait=True)\n    motor_3.spin_to_position(-90, DEGREES)\n\n\ndef marbleD():\n    brain.screen.print(\"yellow\")\n    motor_3.spin_to_position(-90, DEGREES)\n\n\n# --- Main Loop ---\n\noptical_1.set_light(LedStateType.ON)\n\nlast = [\"E\", \"E\"]\npos = 0\n\nwhile True:\n    wait(50, MSEC)  #polling was 300ms, now 50ms\n    motor_3.spin_to_position(0,DEGREES)\n\n    x = optical_1.hue()\n    y = optical_1.brightness()\n\n    # Update screen with live hue and brightness\n    brain.screen.clear_row(1)\n    brain.screen.clear_row(2)\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(x)\n    brain.screen.set_cursor(2, 1)\n    brain.screen.print(y)\n    brain.screen.clear_row(3)\n    brain.screen.set_cursor(3, 1)\n\n    # Store colour reading into rolling buffer\n    if bounds(x, y, \"A\"):\n        last[pos % 2] = \"A\"\n    elif bounds(x, y, \"B\"):\n        last[pos % 2] = \"B\"\n    elif bounds(x, y, \"C\"):\n        last[pos % 2] = \"C\"\n    else:\n        last[pos % 2] = \"E\"\n\n    pos += 1\n\n    # Check for 2 consecutive matching non-empty readings\n    if last[0] == last[1] and last[0] not in (\"E\", \",\"):\n        detected = last[0]\n\n        # Reset motors non-blocking, brief settle time\n        #motor_2.spin_to_position(0, DEGREES, wait=False)\n        #motor_3.spin_to_position(0, DEGREES, wait=False)\n        #wait(200, MSEC)\n\n        if detected == \"A\":\n            marbleA()\n        elif detected == \"B\":\n            marbleB()\n        elif detected == \"C\":\n            marbleC()\n        elif detected == \"D\":\n            marbleD()\n\n        # Clear buffer to prevent immediate re-trigger\n        last = [\"E\", \"E\"]\n        pos = 0\n\n    else:\n        brain.screen.print(\"scanning...\")","textLanguage":"python","robotConfig":[{"port":[1],"name":"optical_1","customName":false,"deviceType":"Optical","deviceClass":"optical","setting":{},"triportSourcePort":22},{"port":[2],"name":"motor_2","customName":false,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[3],"name":"motor_3","customName":false,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22}],"slot":0,"platform":"EXP","sdkVersion":"20240802.15.00.00","appVersion":"4.64.0","fileFormat":"2.0.0","targetBrainGen":"First","v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}